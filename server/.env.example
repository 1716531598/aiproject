# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=ironman-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=888

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=ironman

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_password
REDIS_DB=0

# Dashboard (mock or real)
DASHBOARD_MODE=mock
