    "@antv/l7-maps": "^2.19.9",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@umijs/max": "^4.5.3",
    "ahooks": "^3.9.0",
    "antd": "^5.29.2",
    "antd-style": "^3.7.1",
    "base-64": "^1.0.0",
